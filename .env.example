# ===== Core =====
APP_NAME="AI Real Estate Platform"
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== Database =====
# Postgres (prod/dev). For quick local dev you may use sqlite:  sqlite:///./dev.db
DATABASE_URL=postgresql+psycopg2://resto:restopass@localhost:5433/realestate_platform

# ===== AI provider (configurable) =====
# One of: gemini | ollama | openrouter | openai
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ===== Property data source =====
# Free tier. Leave blank to use the built-in demo dataset.
RENTCAST_API_KEY=
DEFAULT_CITY=Dallas
DEFAULT_STATE=TX

# ===== Frontend (Flask) =====
API_BASE_URL=http://localhost:8000
FLASK_SECRET_KEY=change-me-too
