# ===== Core =====
APP_NAME="AI Real Estate Platform"
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== Database =====
# Postgres (prod/dev). For quick local dev you may use sqlite:  sqlite:///./dev.db
DATABASE_URL=postgresql+psycopg2://resto:restopass@localhost:5433/realestate_platform

# ===== AI provider (configurable) =====
# One of: gemini | ollama | openrouter | openai
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ===== Property data source =====
# DATA_SOURCE: auto | rentcast | opendata | demo
#   auto     -> rentcast if RENTCAST_API_KEY set, else opendata if OPENDATA_URL set, else demo
DATA_SOURCE=auto

# Option 1 — RentCast free tier (real US for-sale listings). Blank => not used.
RENTCAST_API_KEY=

# Option 2 — LEGAL, free, no-key public open data (e.g. a Socrata property dataset).
#   These portals publish data for public reuse (ToS-friendly, unlike scraping listing sites).
#   Example: https://data.cityofchicago.org/resource/<id>.json
OPENDATA_URL=
OPENDATA_APP_TOKEN=                 # optional Socrata app token (free; higher rate limits)
OPENDATA_SOURCE_LABEL=opendata
# Optional: map dataset column names onto our schema, e.g.
#   {"price":["sale_price"],"address":["property_location"],"beds":["bedroom_count"]}
OPENDATA_FIELD_MAP=

DEFAULT_CITY=Dallas
DEFAULT_STATE=TX

# ===== Email / SMTP (free via a Gmail App Password) =====
# Leave blank to disable email — password-reset tokens are then returned in the dev
# response and deal alerts are simply skipped (nothing breaks).
# Gmail: enable 2-Step Verification, then create an App Password at
#   https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME="AI Real Estate Platform"
APP_BASE_URL=http://localhost:5001
PASSWORD_RESET_EXPIRE_MINUTES=30

# ===== Frontend (Flask) =====
API_BASE_URL=http://localhost:8000
FLASK_SECRET_KEY=change-me-too
